# Example environment variables for AiXWorkForce360 backend
NODE_ENV=development
PORT=8000
API_VERSION=v1
DATABASE_URL=postgresql://user:password@localhost:5432/aixworkforce360
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aixworkforce360
DB_USER=postgres
DB_PASSWORD=password
JWT_SECRET=your-super-secret-jwt-key
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=7d
SSO_INTERNAL_ENABLED=true
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=
SSO_AZURE_CLIENT_ID=
SSO_AZURE_TENANT_ID=
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
STORAGE_TYPE=local
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=./uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=aixworkforce360-files
EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@aixworkforce360.com
WS_ENABLED=true
WS_CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=info
SENTRY_DSN=
CORS_ORIGIN=http://localhost:3000,https://yourdomain.com
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
APP_NAME=AiXWorkForce360
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
